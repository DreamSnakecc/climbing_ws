<launch>
  <arg name="enable_state_logger" default="false" />
  <arg name="mission_auto_start" default="true" />
  <arg name="enable_auto_adhesion_commands" default="true" />

  <rosparam command="load" file="$(find climbing_description)/config/robot.yaml" />

  <node pkg="climbing_state_estimator" type="mocap_bridge.py" name="mocap_bridge" output="screen" />
  <node pkg="climbing_state_estimator" type="state_estimator.py" name="state_estimator" output="screen" />
  <node pkg="climbing_control_core" type="body_planner.py" name="body_planner" output="screen" />
  <node pkg="climbing_control_core" type="stance_force_optimizer.py" name="stance_force_optimizer" output="screen" />
  <node pkg="climbing_control_core" type="swing_leg_controller.py" name="swing_leg_controller" output="screen" />
  <node pkg="climbing_control_core" type="mission_supervisor.py" name="mission_supervisor" output="screen">
    <param name="auto_start" value="$(arg mission_auto_start)" />
    <param name="enable_auto_adhesion_commands" value="$(arg enable_auto_adhesion_commands)" />
  </node>

  <group if="$(arg enable_state_logger)">
    <node pkg="climbing_control_core" type="state_logger.py" name="state_logger" output="screen">
      <rosparam command="load" file="$(find climbing_description)/config/robot.yaml" ns="" />
    </node>
  </group>
</launch>